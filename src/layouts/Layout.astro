---
interface Props {
  title: string;
  lang: 'en' | 'fr';
  description?: string;
}

const {
  title,
  lang,
  description = lang === 'fr'
    ? 'Une campagne qui célèbre les contributeur·ice·s aux biens communs numériques.'
    : 'A campaign celebrating contributors to digital commons.',
} = Astro.props;

const base = (import.meta.env.BASE_URL + '/').replace('//', '/');
const canonicalFr = `${Astro.site}${base}fr/`;
const canonicalEn = `${Astro.site}${base}`;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="alternate" hreflang="en" href={canonicalEn} />
    <link rel="alternate" hreflang="fr" href={canonicalFr} />
    <link rel="icon" type="image/svg+xml" href={`${base}logo-icon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-zinc-950 text-white font-sans antialiased">
    <slot />
  </body>
</html>
