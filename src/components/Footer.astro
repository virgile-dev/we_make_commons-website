---
interface Props {
  lang: 'en' | 'fr';
}
const { lang } = Astro.props;
const base = (import.meta.env.BASE_URL + '/').replace('//', '/');

const submitUrl =
  'https://grist.liiib.re/o/we-make-commons/forms/a4AEHWqiSqh33j3KeMHfTf/8';
const hofUrl =
  'https://grist.liiib.re/o/we-make-commons/rprjQEq3gHEF/Campaign-We-Make-Commons/p/3';
---

<footer class="bg-zinc-950 border-t border-zinc-800 py-12 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row items-start justify-between gap-10">
      <!-- Logo + tagline -->
      <div class="max-w-xs">
        <a href={base}>
          <img
            src={`${base}logo.png`}
            alt="We Make Commons"
            class="h-12 w-auto mb-4"
          />
        </a>
        <p class="text-zinc-500 text-sm leading-relaxed">
          {
            lang === 'fr'
              ? 'Une campagne pour célébrer les contributeur·ice·s aux biens communs numériques, portée par Code for France.'
              : 'A campaign celebrating contributors to digital commons, organized by Code for France.'
          }
        </p>
      </div>

      <!-- Links -->
      <div class="grid grid-cols-2 gap-10 text-sm">
        <div>
          <p class="text-zinc-400 font-semibold mb-3">
            {lang === 'fr' ? 'Participer' : 'Participate'}
          </p>
          <ul class="space-y-2">
            <li>
              <a
                href={submitUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-zinc-500 hover:text-white transition-colors"
              >
                {lang === 'fr' ? '✊ Soumettre ma contribution' : '✊ Submit my contribution'}
              </a>
            </li>
            <li>
              <a
                href="#hall-of-fame"
                class="text-zinc-500 hover:text-white transition-colors"
              >
                {lang === 'fr' ? '👏 Tableau d\'honneur' : '👏 Hall of Fame'}
              </a>
            </li>
            <li>
              <a
                href={hofUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-zinc-500 hover:text-white transition-colors"
              >
                {lang === 'fr' ? '📊 Registre complet' : '📊 Full registry'}
              </a>
            </li>
          </ul>
        </div>
        <div>
          <p class="text-zinc-400 font-semibold mb-3">
            {lang === 'fr' ? 'La campagne' : 'The campaign'}
          </p>
          <ul class="space-y-2">
            <li>
              <a
                href="#why"
                class="text-zinc-500 hover:text-white transition-colors"
              >
                {lang === 'fr' ? 'Pourquoi' : 'Why'}
              </a>
            </li>
            <li>
              <a
                href="#how"
                class="text-zinc-500 hover:text-white transition-colors"
              >
                {lang === 'fr' ? 'Comment' : 'How'}
              </a>
            </li>
            <li>
              <a
                href="#join"
                class="text-zinc-500 hover:text-white transition-colors"
              >
                {lang === 'fr' ? 'Organisations' : 'Organizations'}
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Lang toggle -->
      <div>
        <p class="text-zinc-400 font-semibold text-sm mb-3">Language</p>
        <div class="flex gap-2">
          <a
            href={base}
            class={`px-3 py-1.5 rounded text-sm transition-colors ${lang === 'en' ? 'bg-wmc-yellow text-black font-semibold' : 'text-zinc-400 hover:text-white'}`}
          >
            English
          </a>
          <a
            href={`${base}fr/`}
            class={`px-3 py-1.5 rounded text-sm transition-colors ${lang === 'fr' ? 'bg-wmc-yellow text-black font-semibold' : 'text-zinc-400 hover:text-white'}`}
          >
            Français
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-10 pt-6 border-t border-zinc-800 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-zinc-600"
    >
      <p>
        {
          lang === 'fr'
            ? 'Organisée par '
            : 'Organized by '
        }
        <a
          href="https://codefor.fr/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-zinc-400 transition-colors"
        >
          Code for France
        </a>
      </p>
      <p>
        {
          lang === 'fr'
            ? 'Données hébergées sur '
            : 'Data hosted on '
        }
        <a
          href="https://grist.liiib.re/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-zinc-400 transition-colors"
        >
          Grist / Liiib.re
        </a>
      </p>
    </div>
  </div>
</footer>
